# ─────────────────────────────────────────────────────────
#  CBK Banking System — Environment Variables
#  Copy this to .env and fill in your real values
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cbk_banking
DB_USER=cbk_admin
DB_PASSWORD=your_strong_db_password_here
DB_SSL=true

# JWT (use a long random string — min 64 chars)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=8h

# Admin credentials (set at first run via npm run migrate)
ADMIN_USERNAME=cbk_admin
ADMIN_PASSWORD=Admin@CBK2024!

# Africa's Talking (USSD + SMS)
AT_API_KEY=atsk_11faa0a4015299f468af9c179660e40246b7d3b27a4936d34428e04b755739fc3121ae33
AT_USERNAME=cbkbankingmk2
AT_SENDER_ID=CBK-BANK
AT_USSD_CODE=*384*1#

# CBK Business Rules
CBK_MIN_BALANCE=100
CBK_TRANSACTION_FEE_PERCENT=0.5
CBK_MAX_SINGLE_TRANSACTION=1000000
CBK_MAX_DAILY_WITHDRAWAL=500000
